{
  "expo": {
    "name": "Afri Fast",
    "slug": "afri-fast",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.afrifast.app"
    },
    "android": {
      "package": "com.afrifast.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "webpack",
      "themeColor": "#E6F4FE",
      "description": "African meal fasting and calorie tracker",
      "name": "Afri Fast",
      "shortName": "Afri Fast"
    },
    "plugins": [
      "expo-audio",
      "expo-notifications",
      [
        "expo-camera",
        {
          "cameraPermission": "Afri Fast needs camera access to scan your meals."
        }
      ]
    ]
  }
}
